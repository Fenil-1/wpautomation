# ---------------------------------------------------------------------------
# wa-broadcast-backend — environment template
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is git-ignored; never commit real secrets.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
APP_NAME=wa-broadcast-backend
APP_VERSION=0.1.0

# HTTP server
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# PostgreSQL (used by Prisma)
# On a Homebrew macOS install, Postgres usually authenticates as your system
# user with no password (trust auth), e.g.:  postgresql://$(whoami)@localhost:5432/wa_broadcast?schema=public
# On a standard/Docker install, use the postgres superuser:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wa_broadcast?schema=public

# Redis (used by the general client and, later, BullMQ)
REDIS_URL=redis://localhost:6379

# Local persisted state (WhatsApp auth credentials + session metadata)
DATA_DIR=.data

# Broadcast delivery pacing + retries (Stage 3B)
SEND_DELAY_MIN_MS=800
SEND_DELAY_MAX_MS=2500
MAX_SEND_RETRIES=3
